# Common configuration for all ESP32 targets
# BleMesh2MQTT Bridge - Base settings shared across all targets
# This file is applied first, then target-specific sdkconfig.defaults.{TARGET} files
#
# THIS FILE CONTAINS ALL OPTIMIZATIONS AND SETTINGS FROM GIT HISTORY
# Diff between first commit (157176e) and last commit (bb9be86)

#
# Compiler Optimizations (Size)
#
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_DISABLE=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTION_LEVEL=0
CONFIG_COMPILER_OPTIMIZATION_LEVEL_RELEASE=y
# CONFIG_COMPILER_CXX_EXCEPTIONS is not set
CONFIG_BOOTLOADER_COMPILER_OPTIMIZATION_SIZE=y

# Legacy optimization names (backward compatibility)
CONFIG_OPTIMIZATION_LEVEL_RELEASE=y
CONFIG_OPTIMIZATION_ASSERTION_LEVEL=0
CONFIG_OPTIMIZATION_ASSERTIONS_DISABLED=y

#
# HAL Assertions (DISABLED for size)
#
CONFIG_HAL_DEFAULT_ASSERTION_LEVEL=0

#
# Bluetooth Stack Selection (CRITICAL)
#
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
# CONFIG_BT_NIMBLE_ENABLED is not set
CONFIG_BT_BLUEDROID_PINNED_TO_CORE_0=y
CONFIG_BT_BLUEDROID_PINNED_TO_CORE=0
CONFIG_BT_BLUEDROID_ESP_COEX_VSC=y

# Bluetooth Classic DISABLED (BLE only - saves significant space)
# CONFIG_BT_CLASSIC_ENABLED is not set

#
# BLE Configuration
#
CONFIG_BT_BLE_ENABLED=y
# CONFIG_BT_BLE_BLUFI_ENABLE is not set
CONFIG_BT_BLE_SMP_ENABLE=y
CONFIG_BT_BLE_SMP_BOND_NVS_FLASH=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_BTC_TASK_STACK_SIZE=3072
CONFIG_BT_BTU_TASK_STACK_SIZE=4512

# BLE Connection Timeouts (Reduced for faster connection)
CONFIG_BT_BLE_ESTAB_LINK_CONN_TOUT=30
CONFIG_BLE_ESTABLISH_LINK_CONNECTION_TIMEOUT=30

# BLE HCI Debug (DISABLED for size)
# CONFIG_BT_HCI_LOG_DEBUG_EN is not set

#
# BLE Mesh Core Configuration
#
CONFIG_BLE_MESH=y
CONFIG_BLE_MESH_HCI_5_0=y
CONFIG_BLE_MESH_V11_SUPPORT=y
CONFIG_BLE_MESH_USE_DUPLICATE_SCAN=y
CONFIG_BLE_MESH_MEM_ALLOC_MODE_INTERNAL=y
CONFIG_BLE_MESH_DEINIT=y

#
# BLE Mesh Mode (Provisioner only, NOT node)
#
# CONFIG_BLE_MESH_NODE is not set

#
# BLE Mesh Provisioner
#
CONFIG_BLE_MESH_PROVISIONER=y
CONFIG_BLE_MESH_MAX_PROV_NODES=25
CONFIG_BLE_MESH_WAIT_FOR_PROV_MAX_DEV_NUM=10
CONFIG_BLE_MESH_PBA_SAME_TIME=2
CONFIG_BLE_MESH_PBG_SAME_TIME=1
CONFIG_BLE_MESH_PROVISIONER_SUBNET_COUNT=3
CONFIG_BLE_MESH_PROVISIONER_APP_KEY_COUNT=3

#
# BLE Mesh Features
#
CONFIG_BLE_MESH_PROV=y
CONFIG_BLE_MESH_PROV_EPA=y
CONFIG_BLE_MESH_PB_ADV=y
CONFIG_BLE_MESH_PB_GATT=y
CONFIG_BLE_MESH_PROXY=y
CONFIG_BLE_MESH_NET_BUF_POOL_USAGE=y
CONFIG_BLE_MESH_CFG_CLI=y

#
# BLE Mesh Storage
#
CONFIG_BLE_MESH_SETTINGS=y
CONFIG_BLE_MESH_STORE_TIMEOUT=0
CONFIG_BLE_MESH_SEQ_STORE_RATE=0
CONFIG_BLE_MESH_RPL_STORE_TIMEOUT=0

#
# BLE Mesh Network Configuration
#
CONFIG_BLE_MESH_SUBNET_COUNT=3
CONFIG_BLE_MESH_APP_KEY_COUNT=3
CONFIG_BLE_MESH_MODEL_KEY_COUNT=3
CONFIG_BLE_MESH_MODEL_GROUP_COUNT=3
CONFIG_BLE_MESH_LABEL_COUNT=3
CONFIG_BLE_MESH_CRPL=10
CONFIG_BLE_MESH_MSG_CACHE_SIZE=10
CONFIG_BLE_MESH_ADV_BUF_COUNT=60
CONFIG_BLE_MESH_IVU_DIVIDER=4
CONFIG_BLE_MESH_TX_SEG_MSG_COUNT=10
CONFIG_BLE_MESH_RX_SEG_MSG_COUNT=10
CONFIG_BLE_MESH_RX_SDU_MAX=384
CONFIG_BLE_MESH_TX_SEG_MAX=32

#
# BLE Mesh Client Models (CRITICAL - Required for light control!)
#
CONFIG_BLE_MESH_GENERIC_ONOFF_CLI=y
CONFIG_BLE_MESH_GENERIC_LEVEL_CLI=y
CONFIG_BLE_MESH_LIGHT_LIGHTNESS_CLI=y
CONFIG_BLE_MESH_LIGHT_CTL_CLI=y
CONFIG_BLE_MESH_LIGHT_HSL_CLI=y
CONFIG_BLE_MESH_LIGHT_LC_CLI=y

#
# BLE Mesh Server Models (DISABLED for size)
#
# CONFIG_BLE_MESH_GATT_PROXY_CLIENT is not set
# CONFIG_BLE_MESH_GENERIC_SERVER is not set
# CONFIG_BLE_MESH_SENSOR_SERVER is not set
# CONFIG_BLE_MESH_TIME_SCENE_SERVER is not set
# CONFIG_BLE_MESH_LIGHTING_SERVER is not set
# CONFIG_BLE_MESH_SRPL_CLI is not set

#
# BLE Mesh Debug (DISABLED for size)
#
# CONFIG_BLE_MESH_DEBUG is not set
# CONFIG_BLE_MESH_TRACE_LEVEL_DEBUG is not set
# CONFIG_BLE_MESH_NET_BUF_TRACE_LEVEL_DEBUG is not set

#
# BLE Mesh Tracing
#
CONFIG_BLE_MESH_TRACE_LEVEL_WARNING=y
CONFIG_BLE_MESH_STACK_TRACE_LEVEL=2
CONFIG_BLE_MESH_NET_BUF_TRACE_LEVEL_WARNING=y
CONFIG_BLE_MESH_NET_BUF_TRACE_LEVEL=2
CONFIG_BLE_MESH_CLIENT_MSG_TIMEOUT=8000

#
# WiFi Configuration
#
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32

# WiFi Provisioning & Reconnection (Custom logic)
CONFIG_WIFI_RECONNECT_UNLIMITED_ATTEMPTS=y
CONFIG_WIFI_RECONNECT_DELAY_MS=10000

# WiFi Advanced Features DISABLED (size optimization)
# CONFIG_WPA_11KV_SUPPORT is not set
# CONFIG_WPA_MBO_SUPPORT is not set
# CONFIG_WPA_DPP_SUPPORT is not set
# CONFIG_WPA_11R_SUPPORT is not set

# WiFi Examples Config (defaults for menuconfig)
CONFIG_ESP_WIFI_SSID="myssid"
CONFIG_ESP_WIFI_PASSWORD="mypassword"
CONFIG_ESP_WIFI_PW_ID=""
CONFIG_ESP_MAXIMUM_RETRY=5
CONFIG_ESP_WIFI_AUTH_WPA2_PSK=y
CONFIG_ESP_STATION_EXAMPLE_WPA3_SAE_PWE_BOTH=y

#
# LWIP Configuration (CORRECTED VALUES)
#
CONFIG_LWIP_MAX_SOCKETS=8
CONFIG_LWIP_SO_REUSE=y
CONFIG_LWIP_SO_REUSE_RXTOALL=y
CONFIG_LWIP_TCPIP_TASK_PRIO=18
CONFIG_LWIP_DNS_SUPPORT_MDNS_QUERIES=y
CONFIG_LWIP_TIMERS_ONDEMAND=y
CONFIG_LWIP_DHCP_DOES_ARP_CHECK=y
CONFIG_LWIP_DHCPS=y
CONFIG_LWIP_DHCPS_LEASE_UNIT=60
CONFIG_LWIP_DHCPS_MAX_STATION_NUM=8
CONFIG_LWIP_DHCPS_STATIC_ENTRIES=y
CONFIG_LWIP_DHCPS_ADD_DNS=y
CONFIG_LWIP_MAX_ACTIVE_TCP=16
CONFIG_LWIP_MAX_LISTENING_TCP=16
CONFIG_LWIP_TCP_MAXRTX=12
CONFIG_LWIP_TCP_SYNMAXRTX=12
CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=3072
CONFIG_LWIP_DHCP_OPTIONS_LEN=69

# IPv6 DISABLED (size optimization)
# CONFIG_LWIP_IPV6 is not set

#
# HTTP Server Configuration
#
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512
CONFIG_HTTPD_ERR_RESP_NO_DELAY=y
CONFIG_HTTPD_PURGE_BUF_LEN=32
CONFIG_HTTPD_WS_SUPPORT=y
CONFIG_HTTPD_SERVER_EVENT_POST_TIMEOUT=2000

#
# MQTT Configuration (CORRECTED - SSL/WebSocket ENABLED)
#
CONFIG_MQTT_PROTOCOL_311=y
CONFIG_MQTT_PROTOCOL_5=y
CONFIG_MQTT_TRANSPORT_SSL=y
CONFIG_MQTT_TRANSPORT_WEBSOCKET=y
CONFIG_MQTT_TRANSPORT_WEBSOCKET_SECURE=y
CONFIG_BROKER_URL="mqtt://mqtt.eclipseprojects.io"

#
# WebSocket Transport
#
CONFIG_WS_TRANSPORT=y
CONFIG_WS_BUFFER_SIZE=1024

#
# LittleFS Configuration
#
CONFIG_LITTLEFS_MAX_PARTITIONS=3
CONFIG_LITTLEFS_PAGE_SIZE=256
CONFIG_LITTLEFS_OBJ_NAME_LEN=64
CONFIG_LITTLEFS_READ_SIZE=128
CONFIG_LITTLEFS_WRITE_SIZE=128
CONFIG_LITTLEFS_LOOKAHEAD_SIZE=128
CONFIG_LITTLEFS_CACHE_SIZE=512
CONFIG_LITTLEFS_BLOCK_CYCLES=512
CONFIG_LITTLEFS_USE_MTIME=y
CONFIG_LITTLEFS_MTIME_USE_SECONDS=y
CONFIG_LITTLEFS_ASSERTS=y
CONFIG_LITTLEFS_MALLOC_STRATEGY_DEFAULT=y

#
# mbedTLS (SSL/TLS)
#
CONFIG_MBEDTLS_INTERNAL_MEM_ALLOC=y
CONFIG_MBEDTLS_ASYMMETRIC_CONTENT_LEN=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
CONFIG_MBEDTLS_SSL_KEEP_PEER_CERTIFICATE=y
CONFIG_MBEDTLS_PKCS7_C=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# CONFIG_MBEDTLS_SSL_PROTO_TLS1_3 is not set

#
# Partition Table (Dual OTA for Xtensa targets: ESP32, ESP32-S3)
#
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/dual-ota.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions/dual-ota.csv"

#
# FreeRTOS Configuration (CORRECTED VALUES)
#
CONFIG_FREERTOS_HZ=100
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=1536
CONFIG_FREERTOS_ISR_STACKSIZE=1536
CONFIG_FREERTOS_TIMER_TASK_PRIORITY=1
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=4096
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_FREERTOS_SUPPORT_STATIC_ALLOCATION=y

#
# ESP System Configuration
#
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=2304
CONFIG_ESP_MAIN_TASK_STACK_SIZE=3584
CONFIG_ESP_MAIN_TASK_AFFINITY_CPU0=y
CONFIG_ESP_MAIN_TASK_AFFINITY=0x0
CONFIG_ESP_IPC_TASK_STACK_SIZE=1024
CONFIG_ESP_TIMER_TASK_STACK_SIZE=3584

#
# ESP-TLS
#
CONFIG_ESP_TLS_USING_MBEDTLS=y

#
# Watchdog (CORRECTED TIMEOUT)
#
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_INIT=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=5
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=y

#
# Log Configuration (Size Optimization)
#
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
# CONFIG_LOG_MAXIMUM_LEVEL_VERBOSE is not set
CONFIG_LOG_MAXIMUM_LEVEL=3
# CONFIG_LOG_COLORS is not set
CONFIG_BOOTLOADER_LOG_LEVEL_INFO=y
CONFIG_BOOTLOADER_LOG_LEVEL=3
# CONFIG_BOOTLOADER_LOG_COLORS is not set

#
# Serial Flasher Config
#
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
# Flash frequency is target-specific (see sdkconfig.defaults.{target})
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

#
# Security (Disabled)
#
CONFIG_SECURE_BOOT=n
CONFIG_SECURE_FLASH_ENC_ENABLED=n

#
# Power Management (DISABLED for size)
#
# CONFIG_PM_ENABLE is not set

#
# Newlib (Use nano format for smaller binary - compact printf/scanf)
#
# CONFIG_NEWLIB_NANO_FORMAT is not set

#
# SNTP
#
# CONFIG_LWIP_SNTP_STARTUP_DELAY is not set

#