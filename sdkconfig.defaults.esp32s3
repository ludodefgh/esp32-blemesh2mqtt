# ESP32-S3-specific configuration overrides
# Applied after sdkconfig.defaults when building for ESP32-S3

# ESP32-S3 has good resources - can support more connections
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=8

# ESP32-S3 specific optimizations - 240MHz CPU
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Flash frequency - 40MHz
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y
