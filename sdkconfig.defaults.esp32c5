# ESP32-C5-specific configuration overrides
# Applied after sdkconfig.defaults when building for ESP32-C5

# ESP32-C5 balanced resources
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=5

# RISC-V specific - 240MHz CPU frequency (C5 supports higher than C3/C6)
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Flash frequency - 40MHz
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y

# Partition table - Single OTA (no rollback) for larger RISC-V binaries
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/single-ota.csv"
